# 要約のやり方（推奨: api + OpenAI）
#   api   = クラウドAPI（OpenAI 推奨。月200件で約30円）
#   rule  = AIなし（キーワードで抜き出し）
#   ollama = ローカルOllama
SUMMARIZE_MODE=api

# ----- OpenAI（推奨） -----
# https://platform.openai.com/api-keys でキー取得
# https://platform.openai.com/settings/billing で $5 程度チャージ
OPENAI_API_KEY=sk-xxxxxxxx
# OPENAI_MODEL=gpt-4o-mini

# ----- 他のAPIを使う場合 -----
# Groq（無料）: OPENAI_BASE_URL=https://api.groq.com/openai/v1, OPENAI_MODEL=llama-3.1-8b-instant
# Gemini: OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/, OPENAI_MODEL=gemini-2.0-flash-lite

# 報告書の保存先（SQLite 1ファイル。バックアップはこのファイルをコピー）
# REPORTS_DB=./data/reports.db
# 旧JSON移行用（既存の data/reports/*.json があれば初回にDBへ取り込み）
# REPORTS_DIR=./data/reports

# 外から開く用URL（任意）。./run-tunnel.sh で表示された https://xxxx.loca.lt をここに書くと画面上に表示される
# PUBLIC_URL=https://abc123.loca.lt
